# MiniMax 开放平台（OpenAI 兼容）
# 文档：https://platform.minimax.io/docs/api-reference/text-openai-api
MINIMAX_API_BASE=https://api.minimax.io/v1
MINIMAX_API_KEY=请替换为你的MiniMax_API_KEY
# 会员常用：MiniMax-M2.5 / MiniMax-M2.5-highspeed
MINIMAX_MODEL=MiniMax-M2.5
MINIMAX_PROVIDER=token_plan
MINIMAX_TOKEN_PLAN_BASE=https://api.minimaxi.com/anthropic

# 可选：浏览器调用时在请求头带 X-Demo-Token，与这里一致才放行（不配则不限）
# DEMO_ACCESS_TOKEN=

# 可选：允许跨域的来源（逗号分隔）。不配则用代码内默认（含 https://3737-k.info 与 pages.dev）
# CORS_ORIGINS=https://3737-k.info,https://wanye-etf.pages.dev
